# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Drizzle (Supabase Postgres connection string — transaction-mode pooler, IPv4-only)
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres"

# Resend
RESEND_API_KEY=

# Optional — recipient for new-lead admin notifications (see apps/landing/src/lib/notify-new-lead.ts).
# Falls back to a hardcoded address if unset.
ADMIN_NOTIFICATION_EMAIL=

# Admin app session signing — any random string, e.g. `openssl rand -base64 32`
SESSION_SECRET=
