{
  "name": "quantbridge",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n landing,admin -c blue,green \"npm:dev:landing\" \"npm:dev:admin\"",
    "dev:landing": "npm run dev --workspace=apps/landing",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "build": "npm run build --workspace=apps/landing && npm run build --workspace=apps/admin",
    "lint": "npm run lint --workspace=apps/landing && npm run lint --workspace=apps/admin",
    "db:generate": "npm run generate --workspace=packages/db",
    "db:migrate": "npm run migrate --workspace=packages/db",
    "db:push": "npm run push --workspace=packages/db",
    "db:studio": "npm run studio --workspace=packages/db"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
